[11.2, "o", "  \u001b[32m✓\u001b[0m Indexed 46 chunks from 26 files\r\n"]
[11.8, "o", "\r\n"]
[12.0, "o", "  Done!  Restart Claude Code to activate CCE.\r\n"]
[13.0, "o", "\r\n"]
[13.5, "o", "\u001b[1;36m# Step 3: Search — AI gets precise chunks instead of whole files\u001b[0m\r\n"]
[14.0, "o", "\u001b[32m❯\u001b[0m cce search 'how does authentication work'\r\n"]
[14.5, "o", "\r\n"]
[14.8, "o", "  ── Search · how does authentication work ─────────\r\n"]
[15.0, "o", "\r\n"]
[15.3, "o", "    1. auth.py:7-12\r\n"]
[15.5, "o", "       \u001b[33mdef create_token(user_id: int) -> str:\u001b[0m\r\n"]
[15.8, "o", "    2. auth.py:14-20\r\n"]
[16.0, "o", "       \u001b[33mdef verify_token(token: str) -> dict:\u001b[0m\r\n"]
[16.3, "o", "    3. database.py:6-22\r\n"]
[16.5, "o", "       \u001b[33mdef init_db():\u001b[0m\r\n"]
[16.8, "o", "\r\n"]
[17.0, "o", "    \u001b[32m✓\u001b[0m 5 results  \u001b[1m1,266 tokens served\u001b[0m vs 28,961 full file tokens\r\n"]
[18.0, "o", "\r\n"]
[18.5, "o", "\u001b[1;36m# Without CCE: Claude reads ALL files → 28,961 tokens\u001b[0m\r\n"]
[19.0, "o", "\u001b[1;36m# With CCE:    Claude gets 3 relevant chunks → 1,266 tokens\u001b[0m\r\n"]
[20.0, "o", "\r\n"]
[20.5, "o", "\u001b[1;36m# Step 4: See your savings\u001b[0m\r\n"]
[21.0, "o", "\u001b[32m❯\u001b[0m cce savings\r\n"]
[21.5, "o", "\r\n"]
[21.8, "o", "  my-fastapi-project · 14 queries\r\n"]
[22.0, "o", "\r\n"]
[22.3, "o", "  ⛁ ⛶ ⛶ ⛶ ⛶ ⛶ ⛶ ⛶ ⛶ ⛶  \u001b[1;32m95%\u001b[0m tokens saved\r\n"]
[22.8, "o", "\r\n"]
[23.0, "o", "  \u001b[2mWithout CCE\u001b[0m   \u001b[1m48.0k\u001b[0m  tokens   $0.24\r\n"]
[23.3, "o", "  \u001b[32mWith CCE\u001b[0m      \u001b[1m2.4k\u001b[0m   tokens   $0.01\r\n"]
[23.6, "o", "  ──────────────────────────────────────────\r\n"]
[23.9, "o", "  \u001b[1;32mSaved\u001b[0m         \u001b[1;32m45.6k\u001b[0m  tokens   \u001b[1;32m$0.23\u001b[0m\r\n"]
[24.5, "o", "\r\n"]
[24.8, "o", "  How:  retrieval 93%  +  compression 2%\r\n"]
[25.3, "o", "  Cost estimate based on Opus input pricing ($5/1M tokens)\r\n"]
[26.5, "o", "\r\n"]
[27.0, "o", "\u001b[1;36m# That's it. Your AI assistant now searches instead of re-reading.\u001b[0m\r\n"]
[27.5, "o", "\u001b[1;36m# pip install code-context-engine && cce init\u001b[0m\r\n"]
