{"version": 2, "width": 100, "height": 35, "timestamp": 1746115200, "env": {"SHELL": "/bin/zsh", "TERM": "xterm-256color"}, "title": "CCE: Install, Index, Search, Save Tokens"}
[0.5, "o", "\u001b[1;36m# Code Context Engine — Install and see savings in 60 seconds\u001b[0m\r\n"]
[1.5, "o", "\u001b[1;36m# Step 1: Install\u001b[0m\r\n"]
[2.0, "o", "\u001b[32m❯\u001b[0m pip install code-context-engine\r\n"]
[2.5, "o", "Resolved 75 packages in 1.2s\r\n"]
[2.8, "o", "Installed 75 packages\r\n"]
[3.2, "o", " + code-context-engine==0.4.4\r\n"]
[3.8, "o", "Installed 3 executables: cce, cce-savings, code-context-engine\r\n"]
[4.5, "o", "\r\n"]
[5.0, "o", "\u001b[1;36m# Step 2: Index your project\u001b[0m\r\n"]
[5.5, "o", "\u001b[32m❯\u001b[0m cd ~/my-fastapi-project\r\n"]
[6.0, "o", "\u001b[32m❯\u001b[0m cce init\r\n"]
[6.5, "o", "\r\n"]
[6.8, "o", "  Code Context Engine  ·  my-fastapi-project\r\n"]
[7.0, "o", "  ────────────────────────────────────────────\r\n"]
[7.3, "o", "\r\n"]
[7.6, "o", "  Checking embedding model... ready\r\n"]
[8.0, "o", "  ✓ MCP server registered in .mcp.json\r\n"]
[8.3, "o", "  ✓ CLAUDE.md created with CCE instructions\r\n"]
[8.6, "o", "  ✓ SessionStart hook installed for CCE status\r\n"]
[8.9, "o", "  ✓ Memory hooks installed  (5 hooks)\r\n"]
[9.5, "o", "\r\n"]
[9.8, "o", "  Indexing project...\r\n"]
[10.2, "o", "    Embedding 46 chunks...\r\n"]
